// LIVE DATA LOADER — reads JSON written by fetch_nem.py
// Expected layout (relative to this HTML file):
//   ./data/history_30d.json   { updated, regions: { NSW1: [{t,period,rrp,demand,availGen,reserve}, ...] } }
//   ./data/forecast.json      { updated, regions: { NSW1: [{timestamp,pred,lo,hi}, ...] } }
//   ./data/anomalies.json     { updated, items: [{timestamp,region,rrp,z,severity,msg}, ...] }
//   ./data/meta.json          { last_updated, source, ... }
// ============================================================
async function loadLiveData() {
  try {
    const [histRes, fcRes, anRes, metaRes] = await Promise.all([
      fetch('./data/history_30d.json', { cache: 'no-store' }),
      fetch('./data/forecast.json',    { cache: 'no-store' }),
      fetch('./data/anomalies.json',   { cache: 'no-store' }),
      fetch('./data/meta.json',        { cache: 'no-store' }),
    ]);
    if (!histRes.ok) throw new Error(`history_30d.json HTTP ${histRes.status}`);
    const hist = await histRes.json();
    const fc   = fcRes.ok ? await fcRes.json() : { regions: {} };
    const an   = anRes.ok ? await anRes.json() : { items: [] };
    const meta = metaRes.ok ? await metaRes.json() : {};

    // Convert history → same shape as synthetic data
    for (const region of Object.keys(REGIONS)) {
      const rows = hist.regions?.[region] || [];
      if (!rows.length) continue;
      const fcRows = fc.regions?.[region] || [];
      const lastHistT = rows.length ? new Date(rows[rows.length - 1].t) : new Date();

      dataCache[region] = [
        ...rows.map(r => ({
          t: new Date(r.t),
          settlement: r.t.replace('T', ' ').slice(0, 16),
          period: r.period,
          rrp: r.rrp,
          demand: r.demand,
          availGen: r.availGen,
          reserve: r.reserve,
          isFuture: false,
        })),
        ...fcRows.map(f => ({
          t: new Date(f.timestamp),
          settlement: f.timestamp.replace('T', ' ').slice(0, 16),
          period: 0,
          rrp: f.pred,
          demand: rows.length ? rows[rows.length - 1].demand : 0,
          availGen: rows.length ? rows[rows.length - 1].availGen : 0,
          reserve: 0,
          isFuture: true,
        })),
      ];
    }
    remoteForecast = fc;
    remoteAnomalies = an;
    dataSource = 'live';

    // Status badge
    const statusEl = document.querySelector('.status-dot');
    if (statusEl) {
      statusEl.textContent = 'Live · ' + (meta.last_updated ? new Date(meta.last_updated).toUTCString().slice(17, 22) : '');
    }
    const footerInfo = document.querySelector('footer > div:first-child');
    if (footerInfo && meta.source) {
      footerInfo.textContent = 'NEM PD Terminal · ' + meta.source + ' · Last update: ' + (meta.last_updated || '—');
    }
    console.log(`[NEM] Loaded live data — ${meta.source || 'unknown source'}`);
    return true;
  } catch (e) {
    console.warn('[NEM] Live data unavailable, using synthetic fallback:', e.message);
    dataSource = 'synthetic';
    const statusEl = document.querySelector('.status-dot');
    if (statusEl) statusEl.textContent = 'Demo Sim';
    return false;
  }
}

// ============================================================
// FORECAST — prefers remote ML forecast from fetch_nem.py;
// falls back to client-side ensemble when remote unavailable.
// ============================================================
function forecastNext24(data) {
  // If we have remote ML forecast, use it
  if (remoteForecast && remoteForecast.regions && remoteForecast.regions[currentRegion]) {
    const fc = remoteForecast.regions[currentRegion];
    if (fc.length > 0) {
      return fc.slice(0, 24).map(f => ({
        t: new Date(f.timestamp),
        pred: f.pred,
        lo: f.lo,
        hi: f.hi,
      }));
    }
  }
  // Fallback: client-side weighted ensemble
  const history = data.filter(d => !d.isFuture);
  const future = data.filter(d => d.isFuture);
  const forecasts = [];
  for (const pt of future) {
    const hh = pt.t.getHours() + pt.t.getMinutes() / 60;
    const dow = pt.t.getDay();
    // (a) same hour-of-day across previous 14 days
    const sameTOD = history.filter(h =>
      Math.abs(h.t.getHours() - pt.t.getHours()) < 0.1 &&
      h.t.getMinutes() === pt.t.getMinutes() &&
      (pt.t - h.t) < 14 * 86400000
    );
    const todAvg = sameTOD.reduce((s, h) => s + h.rrp, 0) / Math.max(1, sameTOD.length);
    const todStd = Math.sqrt(sameTOD.reduce((s, h) => s + Math.pow(h.rrp - todAvg, 2), 0) / Math.max(1, sameTOD.length));
    // (b) recent autoregressive: weighted last 8 obs
    const recent = history.slice(-8);
    const recentAvg = recent.reduce((s, h) => s + h.rrp, 0) / recent.length;
    // (c) demand elasticity
    const demRatio = pt.demand / (sameTOD.reduce((s, h) => s + h.demand, 0) / Math.max(1, sameTOD.length));
    const elasticity = (demRatio - 1) * todAvg * 0.6;

    const pred = 0.55 * todAvg + 0.25 * recentAvg + 0.20 * (todAvg + elasticity);
    forecasts.push({
      t: pt.t,
      pred,
      lo: pred - 1.28 * todStd,  // ~80% interval
      hi: pred + 1.28 * todStd,
      actualSoFar: null
    });
  }
  return forecasts;
}

// ============================================================
// ANOMALY DETECTION — prefers remote results; else MAD z-score.
// ============================================================
function detectAnomalies(data) {
  // Remote anomalies for this region, if available
  if (remoteAnomalies && remoteAnomalies.items) {
    const filtered = remoteAnomalies.items
      .filter(a => a.region === currentRegion)
      .map(a => ({
        ...a,
        t: new Date(a.timestamp),
        settlement: a.timestamp.replace('T', ' ').slice(0, 16),
      }));
    if (filtered.length > 0) return filtered;
  }
  // Fallback: compute client-side
  const history = data.filter(d => !d.isFuture);
  const prices = history.map(d => d.rrp);
  const median = [...prices].sort((a, b) => a - b)[Math.floor(prices.length / 2)];
  const mad = [...prices].map(p => Math.abs(p - median)).sort((a, b) => a - b)[Math.floor(prices.length / 2)];
  const robustStd = mad * 1.4826 || 1;
  const anomalies = [];
  for (const d of history) {
    const z = (d.rrp - median) / robustStd;
    if (Math.abs(z) > 2.5) {
      anomalies.push({
        ...d,
        z,
        severity: Math.abs(z) > 4 ? 'spike' : 'warn',
        msg: d.rrp < 0 ? 'Negative price event' :
             d.rrp > 1000 ? 'Extreme price spike' :
             d.rrp > 300 ? 'Price spike' :
             'Anomalous low price'
      });
    }
  }
  return anomalies.sort((a, b) => b.t - a.t);
}

