  data.forEach((d, idx) => {
    // 7d avg for same TOD
    const sameTOD = last7d.filter(h => h.t.getHours() === d.t.getHours() && h.t.getMinutes() === d.t.getMinutes());
    const avg7d = sameTOD.reduce((s, h) => s + h.rrp, 0) / Math.max(1, sameTOD.length);
    const delta = d.rrp - avg7d;
    const tr = document.createElement('tr');
    const flag = d.rrp > 300 ? '🔺 spike' : d.rrp < 0 ? '🔵 neg' : (d.availGen - d.demand) / d.demand < 0.15 ? '⚠ tight' : '';
    tr.innerHTML = `
      <td style="color:var(--text-dim)">${d.settlement}</td>
      <td style="color:var(--text-faint)">${d.period}</td>
      <td><span class="price-cell" style="background:${priceColor(d.rrp)}22;color:${priceColor(d.rrp)}">$${formatPrice(d.rrp)}</span></td>
      <td>${d.demand.toFixed(0)}</td>
      <td>${d.availGen.toFixed(0)}</td>
      <td style="color:${d.reserve / d.demand < 0.15 ? 'var(--red)' : 'var(--text-dim)'}">${(d.reserve / d.demand * 100).toFixed(1)}%</td>
      <td style="color:${delta >= 0 ? 'var(--green)' : 'var(--red)'}">${delta >= 0 ? '+' : ''}${delta.toFixed(1)}</td>
      <td style="color:var(--text-faint)">—</td>
      <td>${flag}</td>
    `;
    tbody.appendChild(tr);
  });
}

function renderAll() {
  renderTickers();
  renderPDChart();
  renderHeatmap();
  renderForecast();
  renderAnomalies();
  renderTable();
}

// Clock
function tickClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toISOString().slice(0, 10) + ' ' + now.toTimeString().slice(0, 8) + ' UTC';
}
setInterval(tickClock, 1000);
tickClock();

// Region tabs
document.querySelectorAll('.region-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.region-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentRegion = btn.dataset.region;
    renderAll();
  });
});
// Range tabs
document.querySelectorAll('#rangeTabs .range-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('#rangeTabs .range-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentRange = parseInt(btn.dataset.range);
    renderPDChart();
  });
});
// Overlay toggles (visual only — toggles dataset visibility)
document.querySelectorAll('#overlayTabs .range-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.toggle('active');
    // Simple re-render preserves toggles
    renderPDChart();
  });
});

// Initial render — try live data first, fall back to synthetic
(async function init() {
  await loadLiveData();
  renderAll();
})();

// Auto-refresh every 5 minutes (skips if tab hidden)
setInterval(async () => {
  if (document.hidden) return;
  const ok = await loadLiveData();
  if (ok) renderAll();
}, 5 * 60 * 1000);
</script>

